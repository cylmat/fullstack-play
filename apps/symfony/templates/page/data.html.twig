{% extends 'base.html.twig' %}

{% block javascripts_add %}
    {{ encore_entry_script_tags('datafactory_action') }}
{% endblock %}

{% block title %}Data{% endblock %}

{% block header %}
    <div class="d-flex justify-content-center">
        <h2 class="pb-4">Data</h2>
    </div>
{% endblock %}



{% block content %}

    <section id="data" class="text-center justify-content-center">

        <div class="row">
            <div class="col">
                <fieldset id="factory" class="border border-2">
                    <legend>Factories</legend>
                    <div>
                        {# <div id="factoriesList">Loading...</div> #}
                        <form>
                            <div class="form-group">
                                <label for="factoryName">Factory name</label>
                                <input id="addFactoryNameInput" type="text" name="factoryName" placeholder="Enter factory name">
                                <button id="addFactoryButton"> + </button>
                            </div>
                        </form>
                    </div>

                </fieldset>
            </div>
        </div>

        <div class="row">
            <div class="col">
                <fieldset id="mysql" class="border border-2">
                    <legend>MySQL</legend>
                    <div>
                        {# <div id="mysqlData">Loading...</div> #}
                        {% for key_data_type, my_data_type in mysql %}
                            ---
                            {{ key_data_type }}:
                            {% for k_data, my_data in my_data_type %}
                                {# {{ k_data }}: {{ my_data }} #}

                                {% for k_item, my_data_item in my_data %}
                                    [{{ k_item }}]: {{ my_data_item }}
                                {% endfor %}
                            {% endfor %}
                            <br/>
                        {% endfor %}
                    </div>

                </fieldset>
            </div>
        </div>

    </section>

{% endblock %}


