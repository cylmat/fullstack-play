{
    "name": "cylmat/symplay",
    "description": "",
    "type": "project",
    "license": "free",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.4",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/doctrine-bundle": "^2",
        "doctrine/doctrine-migrations-bundle": "^3",
        "doctrine/orm": "^3",
        "easycorp/easyadmin-bundle": "^5",
        "nelmio/cors-bundle": "^2",
        "snc/redis-bundle": "^4",
        "symfony/apache-pack": "^1",
        "symfony/asset": "^7",
        "symfony/console": "^7",
        "symfony/doctrine-messenger": "^7",
        "symfony/dotenv": "^7",
        "symfony/expression-language": "^7",
        "symfony/flex": "^2",
        "symfony/form": "^7",
        "symfony/framework-bundle": "^7",
        "symfony/messenger": "^7",
        "symfony/monolog-bundle": "^3",
        "symfony/proxy-manager-bridge": "^6",
        "symfony/runtime": "^7",
        "symfony/security-bundle": "^7",
        "symfony/serializer": "^7",
        "symfony/translation": "^7",
        "symfony/twig-bundle": "^7",
        "symfony/uid": "^7",
        "symfony/validator": "^7",
        "symfony/web-link": "^7",
        "symfony/webpack-encore-bundle": "^2",
        "symfony/workflow": "^7",
        "symfony/yaml": "^7",
        "twig/extra-bundle": "^3",
        "twig/twig": "^3"
    },
    "require-dev": {
        "deptrac/deptrac": "^4",
        "doctrine/doctrine-fixtures-bundle": "^4",
        "friendsofphp/php-cs-fixer": "^3",
        "phpmd/phpmd": "^2",
        "phpunit/phpunit": "^13",
        "rector/rector": "^2",
        "squizlabs/php_codesniffer": "^4",
        "symfony/browser-kit": "^7",
        "symfony/css-selector": "^7",
        "symfony/maker-bundle": "^1",
        "symfony/phpunit-bridge": "^7",
        "symfony/web-profiler-bundle": "^7"
    },
    "config": {
        "bin-dir": "bin",
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "symfony/flex": true,
            "symfony/runtime": true,
            "pestphp/pest-plugin": true,
            "phpro/grumphp": true,
            "wikimedia/composer-merge-plugin": true
        },
        "optimize-autoloader": true,
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "classmap": [],
        "psr-4": {
            "App\\Tests\\": "tests/",
            "spec\\App\\": "spec/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "fix": [
            "php-cs-fixer fix --config=.php-cs-fixer.dist.php --allow-risky=yes --verbose"
        ],
        "test": [
            "phpunit",
            "php -d display_errors=0 bin/phpmd src text phpmd.xml",
            "phpstan analyse -l 6 src"
        ],
        "test-backup": [
            "phpunit",
            "php -d display_errors=0 bin/phpmd src text phpmd.xml",
            "phpstan analyse -l 6 src"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "^7"
        },
        "runtime": {}
    }
}